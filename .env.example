# ModelNexus environment — copy this file to `.env` and fill in the keys you have.
# At least one provider key is required for any chat to do useful work.
# The daemon, CLI, and runtime layers all auto-load this file at startup.

# --- Anthropic (Claude) ---
# Drives: claude-opus-4-7, claude-sonnet-4-6, claude-haiku-4-5, and the moderator.
# Without this key, the LLM-moderator falls back to capability scoring + round-robin.
ANTHROPIC_API_KEY=

# --- OpenAI (GPT + embeddings) ---
# Drives: gpt-5 and the embedding model used by nexus_recall.
# Without this key, recall falls back to keyword-overlap scoring (still works, just dumber).
OPENAI_API_KEY=

# --- Google (Gemini) ---
# Drives: gemini-2-5-pro.
GOOGLE_API_KEY=
# Alternate name some Google examples use — either is accepted.
# GEMINI_API_KEY=

# --- Daemon network (optional) ---
# Default port 24000, bind 127.0.0.1. Override if you run multiple instances.
# MODELNEXUS_PORT=24000
# MODELNEXUS_HOST=127.0.0.1

# --- Data directory (optional) ---
# Default ~/.modelnexus. SQLite, ledgers, and the auth token live here.
# MODELNEXUS_DATA_DIR=
