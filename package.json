{
  "name": "@modelnexus/cli",
  "version": "0.1.0",
  "description": "Multi-model group-chat orchestrator — Claude, GPT, Gemini, and friends talking together with shared knowledge",
  "type": "module",
  "bin": {
    "nexus": "bin/nexus.cjs",
    "mnx": "bin/mnx.cjs"
  },
  "scripts": {
    "dev": "tsx src/cli/nexus.ts",
    "daemon": "tsx src/daemon/server.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "bin/",
    "src/",
    "skills/",
    "capabilities.json",
    "teams.json",
    "tsconfig.json",
    "package.json",
    "README.md"
  ],
  "keywords": [
    "ai",
    "multi-model",
    "group-chat",
    "orchestrator",
    "claude",
    "gpt",
    "gemini",
    "codex",
    "knowledge-graph",
    "agents"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@google/generative-ai": "^0.21.0",
    "better-sqlite3": "^11.3.0",
    "blessed": "^0.1.81",
    "commander": "^12.1.0",
    "dotenv": "^17.4.2",
    "express": "^4.21.0",
    "openai": "^4.70.0",
    "tsx": "^4.19.0",
    "uuid": "^10.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/blessed": "^0.1.25",
    "@types/express": "^5.0.0",
    "@types/node": "^22.7.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.12",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
